# Copy to .env and adjust paths for your machine.

# Repository tree to index (required)
CODEBERG_ROOT=/path/to/repo

# Vector search (optional — omit both for chunk-only mode)
CBERG_MODEL=models/jina-embeddings-v2-base-code/model.onnx
CBERG_INDEX_PATH=/tmp/codeberg.usearch

# Watcher poll timeout in milliseconds (default: 1000)
# CBERG_POLL_MS=1000

# Unix socket for cberg-index IPC (default: /tmp/codeberg-index.sock)
# CBERG_SOCKET=/tmp/codeberg-index.sock

# Path to cberg-index binary (default: beside codeberg-d or PATH)
# CBERG_INDEX_BIN=/path/to/cberg-index

# codeberg-d HTTP listen port (default: 8080)
# CODEBERG_HTTP_PORT=8080

# Periodic git pull for mirror refresh; 0 or unset = disabled
# CODEBERG_GIT_PULL_INTERVAL_SEC=300

# Git repo for pull (default: CODEBERG_ROOT)
# CODEBERG_GIT_DIR=/path/to/repo

# --- Agent (codeberg-ask CLI; `make run-agent`) -----------------------------

# Model the agent uses, as provider:model. Required by `make run-agent`.
# CODEBERG_MODEL=anthropic:claude-haiku-4-5

# API key for the provider named in CODEBERG_MODEL — set the matching one:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Daemon URL the agent queries (default: http://127.0.0.1:8080)
# CODEBERG_DAEMON_URL=http://127.0.0.1:8080
